# Puerto en el que escucha la API.
PORT=8010

# Host de bind. 0.0.0.0 expone en todas las interfaces (necesario en contenedor).
HOST=0.0.0.0

# Nivel de log de la app. Valores: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Tamano de lote por defecto al partir un archivo grande en /split-file.
DEFAULT_CHUNK_SIZE=5000

# Limite maximo del body en MB para uploads.
MAX_CONTENT_LENGTH_MB=50

# Habilita el modo debug de Flask (NO usar en produccion). 0 o 1.
FLASK_DEBUG=0
